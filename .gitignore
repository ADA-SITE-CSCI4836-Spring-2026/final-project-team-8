# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
/TimeIsThe/.utmp/
/TimeIsThe/[Ll]ibrary/
/TimeIsThe/[Tt]emp/
/TimeIsThe/[Oo]bj/
/TimeIsThe/[Bb]uild/
/TimeIsThe/[Bb]uilds/
/TimeIsThe/[Ll]ogs/
/TimeIsThe/[Uu]ser[Ss]ettings/
/TimeIsThe/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/TimeIsThe/*.blend1
/TimeIsThe/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/TimeIsThe/[Mm]emoryCaptures/

# Recordings can get excessive in size
/TimeIsThe/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/TimeIsThe/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
/TimeIsThe/*.DotSettings.user

# Visual Studio cache directory
/TimeIsThe/.vs/

# Gradle cache directory
/TimeIsThe/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/TimeIsThe/ExportedObj/
/TimeIsThe/.consulo/
/TimeIsThe/*.csproj
/TimeIsThe/*.unityproj
/TimeIsThe/*.sln
/TimeIsThe/*.slnx
/TimeIsThe/*.suo
/TimeIsThe/*.tmp
/TimeIsThe/*.user
/TimeIsThe/*.userprefs
/TimeIsThe/*.pidb
/TimeIsThe/*.booproj
/TimeIsThe/*.svd
/TimeIsThe/*.pdb
/TimeIsThe/*.mdb
/TimeIsThe/*.opendb
/TimeIsThe/*.VC.db

# Unity3D generated meta files
/TimeIsThe/*.pidb.meta
/TimeIsThe/*.pdb.meta
/TimeIsThe/*.mdb.meta

# Unity3D generated file on crash reports
/TimeIsThe/sysinfo.txt

# Mono auto generated files
/TimeIsThe/mono_crash.*

# Builds
/TimeIsThe/*.apk
/TimeIsThe/*.aab
/TimeIsThe/*.unitypackage
/TimeIsThe/*.unitypackage.meta
/TimeIsThe/*.app

# Crashlytics generated file
/TimeIsThe/crashlytics-build.properties

# TestRunner generated files
/TimeIsThe/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/TimeIsThe/ServerData
/TimeIsThe/[Aa]ssets/StreamingAssets/aa*
/TimeIsThe/[Aa]ssets/AddressableAssetsData/link.xml*
/TimeIsThe/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/TimeIsThe/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/TimeIsThe/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/TimeIsThe/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/TimeIsThe/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/TimeIsThe/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/TimeIsThe/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
/TimeIsThe/[Aa]ssets/[Ss]ceneDependencyCache*
